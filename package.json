{
  "name": "leaf",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @leaf/shared --filter @leaf/api --filter @leaf/web dev",
    "dev:all": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @leaf/shared build && pnpm -r typecheck",
    "test": "pnpm --filter @leaf/api prisma:generate && pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.3.5",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.0.18"
  }
}
