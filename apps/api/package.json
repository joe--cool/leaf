{
  "name": "@leaf/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src test --ext .ts",
    "test": "vitest run",
    "typecheck": "pnpm prisma:generate && tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@prisma/client": "^6.19.0",
    "@leaf/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cron": "^4.4.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.1",
    "fastify-plugin": "^5.1.0",
    "nodemailer": "^8.0.1",
    "openid-client": "^5.7.0",
    "pino-pretty": "^13.1.3",
    "rrule": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
    "@vitest/coverage-v8": "^4.0.18",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0"
  }
}
